// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum JobStatus {
  SAVED
  APPLIED
  SCREENING
  INTERVIEWING
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
}

enum JobSource {
  JOB_BOARD
  COMPANY_WEBSITE
  REFERRAL
  RECRUITER
  SOCIAL
  EVENT
  OTHER
}

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum InterviewType {
  PHONE_SCREEN
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
  ONSITE
  HR
  FINAL
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InterviewResult {
  PENDING
  PASSED
  FAILED
}

enum JobActivityType {
  STATUS_CHANGE
  NOTE
  INTERVIEW
  COMMUNICATION
  REMINDER
  CUSTOM
}

enum NotificationType {
  JOB_UPDATE
  INTERVIEW_REMINDER
  SYSTEM
  CUSTOM
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String?
  role                UserRole  @default(USER)
  refreshTokenVersion Int       @default(0)
  emailVerified       Boolean   @default(false)
  emailVerifiedAt     DateTime?
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?

  jobs           Job[]
  interviews     Interview[]
  notes          Note[]
  notifications  Notification[]
  companyReviews CompanyReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([isActive])
}

model Company {
  id          String       @id @default(uuid())
  name        String       @unique
  website     String?
  description String?
  industry    String?
  size        CompanySize?
  location    String?
  logoUrl     String?

  jobs    Job[]
  reviews CompanyReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyReview {
  id            String  @id @default(uuid())
  rating        Int?
  processRating Int?
  review        String?

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
}

model Job {
  id             String          @id @default(uuid())
  title          String
  description    String?
  status         JobStatus       @default(SAVED)
  priority       JobPriority     @default(MEDIUM)
  source         JobSource?
  location       String?
  remoteType     RemoteType?
  employmentType EmploymentType?
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?
  url            String?

  appliedAt      DateTime?
  nextActionDate DateTime?
  closedAt       DateTime?
  archivedAt     DateTime?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  interviews Interview[]
  notes      Note[]
  activities JobActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([userId, status])
  @@index([nextActionDate])
}

model Interview {
  id              String          @id @default(uuid())
  type            InterviewType
  status          InterviewStatus @default(SCHEDULED)
  result          InterviewResult @default(PENDING)
  scheduledAt     DateTime
  completedAt     DateTime?
  durationMinutes Int?
  remoteType      RemoteType?
  location        String?
  interviewers    String[]        @default([])
  prepNotes       String?
  feedback        String?
  rating          Int?
  difficulty      Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([jobId])
  @@index([scheduledAt])
  @@index([jobId, status])
}

model Note {
  id      String @id @default(uuid())
  content String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([userId])
}

model JobActivity {
  id          String          @id @default(uuid())
  type        JobActivityType
  description String
  fromStatus  JobStatus?
  toStatus    JobStatus?
  metadata    Json?

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([createdAt])
  @@index([jobId, type])
}

model Notification {
  id      String           @id @default(uuid())
  type    NotificationType
  title   String
  message String
  read    Boolean          @default(false)
  readAt  DateTime?
  data    Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
